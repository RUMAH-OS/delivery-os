{
  "name": "delivery-os-platform",
  "version": "0.1.0-M1",
  "private": true,
  "type": "module",
  "description": "Delivery OS — the RUNNABLE platform runtime (E-PH M1). Boots the engine + reconciler tick loop against a platform-owned DB with ZERO tenant programs registered (the platform-independence milestone).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "boot": "tsx src/index.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
