# Delivery OS platform runtime — the PLATFORM-OWNED DB (never a tenant SoR).
# M1 proves against a LOCAL throwaway Postgres (like CI). Real platform Supabase is the M1-follow-up deploy.
#
# Local throwaway (matches the docker one-liner in README / docker-compose.test.yml):
DATABASE_URL=postgres://os:os@localhost:55433/delivery_os_platform

# Optional runtime knobs:
# PORT=8787              # the /v1 HTTP surface
# OS_NODE_ID=os-runtime-local
# OS_TICK_MS=5000        # heartbeat/reconciler sweep interval
# DB_POOL_MAX=5
