#!/usr/bin/env sh
# Delivery OS — committed pre-push verify-gate (Governance §12).
# Installed via `git config core.hooksPath .githooks` by scripts/new-project.sh, so it
# travels in the repo and fires for ANY git client — the only fully model-independent layer.
# Reuses the same detector as the Claude hook; a non-zero exit blocks the push.
# Gate 1 — verify-gate: the hook emits a deny JSON on stdout when blocking.
if node .claude/hooks/verify-gate.mjs pre-commit <<'EOF' | grep -q '"permissionDecision":"deny"'
{ "tool_input": { "command": "git push" } }
EOF
then
  echo "✗ push blocked by Delivery OS verify-gate: no fresh, passing, independent VERIFY-<slice>.md for changed implementation files." >&2
  echo "  (bootstrap/debug bypass: DELIVERY_OS_GATE_BYPASS=1 git push — logged)" >&2
  exit 1
fi
# Gate 2 — drift-lint: the kernel must not advertise a skill/agent it cannot dispatch (phantom dispatch).
if [ -f .claude/tools/check-os-drift.mjs ]; then
  if ! node .claude/tools/check-os-drift.mjs >&2; then
    echo "✗ push blocked by Delivery OS drift-lint: router/CODEOWNERS advertises something not on disk." >&2
    exit 1
  fi
fi
exit 0
