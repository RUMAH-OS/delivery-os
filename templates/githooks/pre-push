#!/usr/bin/env sh
# Delivery OS — committed pre-push gate (Governance §12). Installed via
# `git config core.hooksPath .githooks`, so it travels in the repo and fires for ANY git
# client — the model-independent backstop. It inspects the COMMITTED PUSH RANGE (not the
# working tree), so a change committed via bare git and pushed with a clean tree is still caught.
# Git feeds ref lines on stdin; pass them straight to the gate in pre-push mode.

# Gate 1 — verify-gate over the push range: impl changes need a verified, independent VERIFY in the push.
if ! cat | node .claude/hooks/verify-gate.mjs pre-push; then
  echo "✗ push blocked by Delivery OS verify-gate: the pushed commits change implementation files" >&2
  echo "  without a verified, independent docs/verify/VERIFY-<slice>.md in the push." >&2
  echo "  (bootstrap/debug bypass: DELIVERY_OS_GATE_BYPASS=1 git push — logged)" >&2
  exit 1
fi

# Gate 2 — drift-lint: the kernel must not advertise a skill/agent it cannot dispatch,
# and os_version must derive from the pin (fail-closed, v4).
if [ -f .claude/tools/check-os-drift.mjs ]; then
  if ! node .claude/tools/check-os-drift.mjs >&2; then
    echo "✗ push blocked by Delivery OS drift-lint: router/CODEOWNERS advertises something not on disk," >&2
    echo "  or a derived os_version field was hand-edited (Governance §7/§14)." >&2
    exit 1
  fi
fi

# Gate 3 — skill-format lint (v4, fail-closed): one hybrid dialect; exemptions live in the validator.
if [ -f .claude/tools/validate-skills.mjs ]; then
  if ! node .claude/tools/validate-skills.mjs >&2; then
    echo "✗ push blocked by Delivery OS validate-skills: a skill violates the ratified format (B31/C6)." >&2
    exit 1
  fi
fi

# Gate 4 — agents:check (S1 ROUTE, fail-closed): every spawnable agent must carry the v6 routing contract
# (kind/capabilities/triggers) — else it is INVISIBLE to deterministic routing (agent-route can't match it).
if [ -f .claude/tools/agents-check.mjs ]; then
  if ! node .claude/tools/agents-check.mjs >&2; then
    echo "✗ push blocked by Delivery OS agents:check: an agent is missing the routing contract (not routable)." >&2
    exit 1
  fi
fi

# Gate 5 — hook-path integrity (fail-closed): every governance/review hook + skill tool reference
# must RESOLVE to a real .mjs and `node --check`-load. A misreferenced/missing hook (the
# founder-action-package MODULE_NOT_FOUND class) can never push. Tool: .claude/tools/check-hook-paths.mjs.
if [ -f .claude/tools/check-hook-paths.mjs ]; then
  if ! node .claude/tools/check-hook-paths.mjs >&2; then
    echo "✗ push blocked by Delivery OS check-hook-paths: a hook/tool reference is missing or fails node --check." >&2
    exit 1
  fi
fi
exit 0
