# ==============================================================================================================
# TEMPLATE  ·  .env.shape   (the daemon env-var NAMES only — NO values)
# ==============================================================================================================
# PURPOSE      The SHAPE of the environment the worker/supervisor daemons read — variable NAMES only, NO values.
#              Non-secret config values are rendered into the launchd plists from the placeholders; SECRET
#              values are read at process start from the System keychain (DOS_SECRET_SOURCE=system-keychain),
#              NEVER from a dotfile or this file. This file is the input to the fail-closed config-doctor /
#              i-config enforce gate's name check. NEO-EXEC-07 §5.7 ; NTS-DOS-v1 §F.
#
# INVARIANT    NO secret values, NO tokens, NO keys, NO real IPs. Every line is NAME= (empty RHS) or NAME=value.
#              The right-hand placeholders are non-secret config the founder fills; the SECRET names below
#              are resolved from the keychain at runtime and intentionally have NO value here.
#
# CONSUMED BY  bootstrap/verify-health.sh (config-doctor --enforce); the launchd plists set the non-secret vars.
#              FOUNDER-INSTALLATION-GUIDE §0 / §6.4.
# ==============================================================================================================

# ── non-secret runtime config (rendered into the plists from the placeholder sheet) ──
DOS_NODE_ID={{NODE_ID}}
DOS_TICK_INTERVAL_MS={{TICK_INTERVAL_MS}}
DOS_HEALTH_BIND={{TAILNET_BIND_ADDR}}
DOS_HEALTH_PORT={{HEALTH_PORT}}
DOS_SECRET_SOURCE=system-keychain
DOS_HC_PERIOD_SECONDS={{HC_PERIOD_SECONDS}}

# ── composition-root seam (P3.1) — module paths the launchd WORKER_ENTRY main wires ──
DOS_WORKER_ENTRY={{WORKER_ENTRY}}
DOS_RUNTIME_TICK={{RUNTIME_TICK_ENTRY}}

# ── SECRET names (resolved from the System keychain at runtime — NO values here, ever) ──
DATABASE_URL=
VERCEL_TOKEN=
CRON_SECRET=
HC_PING_URL=
BREAK_GLASS_PUBKEY=
