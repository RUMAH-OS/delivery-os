# =============================================================================
# node-config.env  —  the founder's resolved placeholder sheet (NON-SECRET)
# -----------------------------------------------------------------------------
# Copy to `node-config.env` and fill in. These map 1:1 to the {{placeholders}} in
# the config-templates (NEO-EXEC-07 §5 / FOUNDER-INSTALLATION-GUIDE §0). The
# bootstrap scripts source this automatically (load_node_config).
#
# !!! NO SECRET VALUE GOES HERE !!!  Secrets are seeded ONLY into the System
# keychain by bootstrap-secrets.sh and are NEVER written to a file or the tree.
# (node-config.env is git-ignored host state; only this .example is committed.)
# =============================================================================

# --- identity ---------------------------------------------------------------
export DOS_NODE_ID="neo-node2"                 # {{NODE_ID}} registry ID (hostname is `neo`)
export DOS_RUNNER_USER="ci-runner"             # {{RUNNER_USER}} non-admin account
export DOS_FOUNDER_EMAIL="founder@example.com"   # {{FOUNDER_EMAIL}} (only group:founder member) — FILL IN; no PII default
export DOS_GH_OWNER="RUMAH-OS"                 # {{OWNER}}
export DOS_GH_REPO="delivery-os"               # {{REPO}}

# --- pinned toolchain -------------------------------------------------------
export DOS_NODE_VERSION="22"                   # {{NODE_VERSION}} match each repo's CI (PLOS 22 / admin 20)
export DOS_VERCEL_CLI_VERSION="48.12.1"        # {{VERCEL_CLI_VERSION}} API floor >= 47.2.2
export DOS_RUNNER_VERSION="2.317.0"            # pinned actions/runner release
export DOS_RUNNER_LABELS="neo,macos,self-hosted"

# --- runtime / ports --------------------------------------------------------
export DOS_TICK_INTERVAL_MS="20000"            # {{TICK_INTERVAL_MS}} 15-30s, NOT 5s
export DOS_HEALTH_PORT="8787"                  # {{HEALTH_PORT}}
export DOS_DISPATCH_PORT="9443"                # {{DISPATCH_PORT}} (latent)
export DOS_NEO_MAGICDNS="neo"                  # {{NEO_MAGICDNS}}
# DOS_TAILNET_BIND_ADDR is resolved at runtime from `tailscale ip -4` (after join);
# set it here once known so install-daemons binds the tailnet iface (NEVER 0.0.0.0):
# export DOS_TAILNET_BIND_ADDR="100.x.y.z"

# --- colima VM profile ------------------------------------------------------
export DOS_COLIMA_CPU="4"                      # {{COLIMA_CPU}}
export DOS_COLIMA_MEMORY_GB="8"                # {{COLIMA_MEMORY_GB}}
export DOS_COLIMA_DISK_GB="60"                 # {{COLIMA_DISK_GB}} (capped; weekly prune)

# --- watchdog ---------------------------------------------------------------
export DOS_HC_PERIOD_SECONDS="60"              # {{HC_PERIOD_SECONDS}}
export DOS_HC_GRACE_SECONDS="300"              # {{HC_GRACE_SECONDS}} (300-600)
export DOS_POLL_INTERVAL_MIN="5"               # {{POLL_INTERVAL_MIN}} Windows pull cadence

# --- logs -------------------------------------------------------------------
export DOS_LOG_DIR="/Users/ci-runner/Library/Logs/delivery-os"   # {{LOG_DIR}}

# --- deploy IDs (NON-SECRET identifiers used only for registry scope) --------
export DOS_VERCEL_ORG_ID=""                    # {{VERCEL_ORG_ID}} e.g. team_1CST...
export DOS_VERCEL_PROJECT_ID=""                # {{VERCEL_PROJECT_ID}}
